<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_picking_form_qrcode_omax" model="ir.ui.view">
            <field name="name">stock.picking.form.orcode.omax</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//label[@for='scheduled_date']" position="before">
                    <field name="qrcode_image" widget="image" class="oe_avatar" style="margin-right:350px;"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
