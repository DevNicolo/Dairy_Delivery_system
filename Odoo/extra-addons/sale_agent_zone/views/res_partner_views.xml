<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add zone field to partner form -->
    <record id="view_partner_form_zone" model="ir.ui.view">
        <field name="name">res.partner.form.zone</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="commission_oca.view_partner_form_agent"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='agent']" position="after">
                <field name="zone_id"
                       string="Zona commerciale"
                       options="{'no_open': False, 'no_quick_create': False}"/>
            </xpath>
        </field>
    </record>

</odoo>
